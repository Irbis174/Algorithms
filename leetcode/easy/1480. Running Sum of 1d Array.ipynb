   "source": [
    "class Solution:\n",
    "    def runningSum(self, nums: List[int]) -> List[int]:\n",
    "        prefix_arr = [0] * len(nums)\n",
    "        prefix_arr[0] = nums[0]\n",
    "\n",
    "        for i in range(1, len(prefix_arr)):\n",
    "            prefix_arr[i] += prefix_arr[i-1] + nums[i]\n",
    "\n",
    "        return prefix_arr"
   ]
  }
 ],
