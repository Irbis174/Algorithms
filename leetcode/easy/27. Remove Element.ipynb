   "source": [
    "class Solution:\n",
    "    def removeElement(self, nums: List[int], val: int) -> int:\n",
    "        k = 0\n",
    "        for right in range(len(nums)):\n",
    "            if nums[right] != val:\n",
    "                nums[right], nums[k] = nums[k], nums[right]\n",
    "                k+=1\n",
    "\n",
    "        return k"
   ]
  }
